# Copy to terraform.tfvars (gitignored). Auth: PROXMOX_VE_* env vars.

proxmox_endpoint = "https://192.168.4.100:8006/"
proxmox_insecure = true
proxmox_node     = "habitvillage"

vm_id   = 320
vm_name = "rhem-prereq-rhel-01"

disk_storage = "local-zfs"

# Cloud image: either upload manually and set volid, OR set a download URL (Proxmox fetches server-side).
# See docs/rhel-guest-image-proxmox.md — RHEL CDN usually needs auth; mirrors / presigned URLs work here.
cloud_image_import_id = "local:import/rhel9-guest-image.qcow2"
# cloud_image_download_url         = "https://internal-mirror.example.com/rhel9-guest.qcow2"
# cloud_image_import_datastore_id  = "local"   # must allow content type "Import"
# cloud_image_download_file_name   = "rhel9-guest-image.qcow2"

# rhem_resource_pool_id = "rhem-eap-prereq"

# Defaults suit a general RHEL 9 VM; for RHEM on this host use e.g. 4 / 16384 / 80 (see docs/04-rhem-1-on-rhel.md)
vm_cores     = 2
vm_memory_mb = 8192
vm_disk_gb   = 50

ci_user = "cloud-user"
ssh_public_key = "ssh-ed25519 AAAA... your-key-here"

ipv4_use_dhcp  = false
ipv4_cidr      = "192.168.4.240/22"
ipv4_gateway   = "192.168.4.1"
dns_servers    = ["192.168.4.220", "1.1.1.1", "8.8.8.8"]
dns_domain     = "rhem-eap.lan"
