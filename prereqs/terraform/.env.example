# Copy to .env (same directory). File is gitignored.
# Use either API token (recommended) or username + password.

# PROXMOX_VE_ENDPOINT=https://192.168.4.100:8006/
# (endpoint is usually already in terraform.tfvars as proxmox_endpoint — optional here)

# PROXMOX_VE_API_TOKEN=terraform@pam!my-token-id=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PROXMOX_VE_USERNAME=root@pam
# PROXMOX_VE_PASSWORD=your-password

# PROXMOX_VE_INSECURE=true
