---
# RHSM registration for all managed RHEL hosts.
# Use either username/password or org + activation key.
rhsm_username: ""
rhsm_password: ""
rhsm_org: ""
rhsm_activation_key: ""

# registry.redhat.io login used on the RHEM host before installing flightctl-services.
# Leave empty to reuse the RHSM username/password.
registry_redhat_io_username: ""
registry_redhat_io_password: ""

# PowerDNS
demo_dns_zone: rhem-eap.lan
demo_dns_api_key: CHANGEME-pdns-api-key
powerdns_auth_repo_url: https://repo.powerdns.com/repo-files/el-auth-50.repo

# Red Hat Edge Manager
rhem_edge_manager_repo: edge-manager-1.0-for-rhel-9-x86_64-rpms
rhem_admin_username: edgemanager-admin
rhem_admin_password: CHANGEME-edgemanager-admin-password
rhem_auth_provider: keycloak
rhem_enable_keycloak: true
rhem_insecure_skip_tls_verify: true

# Keycloak
keycloak_public_url: ""
keycloak_image: quay.io/keycloak/keycloak:26.0.7
keycloak_bootstrap_admin_username: admin
keycloak_bootstrap_admin_password: CHANGEME-keycloak-admin-password
keycloak_realm: edge-manager
keycloak_import_dir: /opt/keycloak/import
keycloak_container_name: keycloak
flightctl_client_id: flightctl-client
edge_manager_admin_username: edgemanager-admin
edge_manager_admin_password: CHANGEME-admin-password
edge_manager_admin_first_name: Edge
edge_manager_admin_last_name: Manager Admin
edge_manager_admin_email: edgemanager-admin@example.com
edge_manager_ops_username: edgemanager-ops
edge_manager_ops_password: CHANGEME-ops-password
edge_manager_ops_first_name: Edge
edge_manager_ops_last_name: Manager Ops
edge_manager_ops_email: edgemanager-ops@example.com

# RHEM OIDC URL overrides.
# Leave blank to derive values from the generated inventory.
rhem_base_domain: ""
rhem_ui_url: ""
rhem_api_url: ""

# AAP (optional)
aap_install_enabled: false
aap_bundle_tar: /path/to/ansible-automation-platform-setup-bundle.tar.gz
aap_install_dir: /opt/aap-setup
aap_admin_username: admin
aap_admin_password: CHANGEME-aap-admin-password
aap_pg_password: CHANGEME-aap-pg-password
aap_api_url: ""
aap_external_api_url: ""
aap_insecure_skip_tls_verify: true
# Leave blank to use the default gateway token endpoint on the AAP host itself.
# Override this for older AAP controller-only deployments if needed.
aap_token_api_url: ""
aap_oauth_application_client_id: ""
aap_edge_manager_oauth_token: ""
aap_edge_manager_oauth_token_file: /etc/ansible-automation-platform/edge-manager-oauth-token

# Satellite (enabled in the full automation stack by default)
satellite_install_enabled: true
satellite_version: "6.17"
satellite_initial_organization: "RHEM Demo"
satellite_initial_location: "Homelab"
satellite_admin_username: admin
satellite_admin_password: CHANGEME-satellite-admin-password
satellite_bootc_product_name: bootc
satellite_bootc_product_label: bootc
satellite_bootc_repository_name: device-os
# Optional: set these once if you want to avoid SSH lookups on the Satellite host
# during later bootc or fleet runs. In the demo they are typically both 1.
satellite_registry_org_id: ""
satellite_registry_product_id: ""

# bootc image build + device enrollment demo
# The bootc build runs on the RHEM host, pushes the image to Satellite by default,
# and generates a bootable qcow2 disk image for the Proxmox device demo path.
bootc_workspace_dir: /var/lib/rhem-demo/bootc
bootc_base_image: registry.redhat.io/rhel9/rhel-bootc:9.7
bootc_use_satellite_registry: true
# Leave bootc_image_repo empty to let automation derive the Satellite registry path.
bootc_image_repo: ""
bootc_local_build_image_repo: localhost/rhem-demo/device-os
bootc_image_tag: v1
bootc_publish_enabled: true
bootc_publish_disk_image_enabled: false
bootc_sign_with_sigstore: false
bootc_build_iso: false
bootc_build_qcow2: true
bootc_registry: ""
bootc_registry_username: ""
bootc_registry_password: ""
bootc_enrollment_signer: enrollment
bootc_enrollment_expiration: 365d
# Leave blank to use the RHEM inventory FQDN, for example https://rhem.rhem-eap.lan:3443.
bootc_rhem_api_url: ""
bootc_installer_config_enabled: true
bootc_installer_nameservers: []
# Leave blank to use ~/.ssh/redhat-edge-manager-demo.pub from the machine running Ansible.
bootc_demo_ssh_public_key_path: ""
device_enrollment_labels:
  - site=homelab
  - fleet=demo

# Demo fleet for Labs 4 and 5
demo_fleet_name: demo
demo_fleet_selector_labels:
  fleet: demo
demo_fleet_image_repo: ""
demo_fleet_image_tag: ""

# Demo application for Lab 6
demo_application_enabled: false
demo_application_name: hello-web
demo_application_type: quadlet
demo_application_title: Red Hat Edge Manager Demo App
demo_application_message: Managed by Red Hat Edge Manager
demo_application_http_port: 8080
demo_application_image_tag: v3
demo_application_runtime_base_image: registry.access.redhat.com/ubi9/httpd-24:latest
demo_application_product_name: bootc
demo_application_product_label: bootc
demo_application_runtime_repo_name: hello-web-runtime
demo_application_package_repo_name: hello-web-package
demo_application_runtime_image_repo: ""
demo_application_package_image_repo: ""
demo_application_wait_timeout_seconds: 900
demo_application_wait_poll_interval_seconds: 15
demo_application_prune_unknown_devices: true
