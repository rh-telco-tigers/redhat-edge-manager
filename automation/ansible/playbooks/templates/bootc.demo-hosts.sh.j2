#!/usr/bin/env bash
set -euo pipefail

tmpfile="$(mktemp)"
trap 'rm -f "$tmpfile"' EXIT

awk '
/^# BEGIN RHEM DEMO HOSTS$/ {skip=1; next}
/^# END RHEM DEMO HOSTS$/ {skip=0; next}
!skip {print}
' /etc/hosts > "$tmpfile"

cat >> "$tmpfile" <<'EOF'
# BEGIN RHEM DEMO HOSTS
{% for host in groups['managed_rhel_hosts'] | default([]) %}{% set host_fqdn = hostvars[host].fqdn | default('') %}{% set host_name = host if host != host_fqdn else '' %}{% set host_domain = host_fqdn.split('.', 1)[1] if '.' in host_fqdn else '' %}{% set long_host_fqdn = (host_name ~ '.' ~ host_domain) if host_name and host_domain and (host_name ~ '.' ~ host_domain) != host_fqdn else '' %}{{ [hostvars[host].ansible_host, host_fqdn, hostvars[host].dns_name | default(''), host_name, long_host_fqdn] | reject('equalto', '') | unique | join(' ') }}
{% endfor %}
# END RHEM DEMO HOSTS
EOF

install -m 0644 "$tmpfile" /etc/hosts
